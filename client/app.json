{
  "expo": {
    "name": "Chain Reaction",
    "slug": "chain-reaction",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/4c02d468-42ff-485a-b062-f9c72f2cf711.png",
    "scheme": "chainreaction",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chainreaction.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/4c02d468-42ff-485a-b062-f9c72f2cf711.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.chainreaction.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "322830cd-9b71-4490-b644-157b2cd197d3"
      }
    },
    "owner": "karnkumarbnk"
  }
}
